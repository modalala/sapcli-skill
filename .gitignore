# SAP CLI Skill - Git 忽略配置

# 环境变量文件（包含敏感信息）
.env
.env.sapcli
.env.*.local
.env.erp-*

# 会话记录文件（包含用户路径和配置信息）
session_*.json

# 个人配置文件
.sapcli-persona.json

# Python 缓存文件
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyRFC 编译文件
*.pyd

# 日志文件
*.log
dev_rfc.log

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db

# 临时文件
tmp/
temp/
*.tmp

# 测试输出
test-output/
coverage/
.pytest_cache/

# 本地配置覆盖
.env.local
.env.*.local

